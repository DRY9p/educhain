<div class="my-3">
  <%= form_with url: messages_path, id: "new_message_form" do |form| %>
    <%= form.label :body, "Message:", class: "mr-2" %>
    <%= form.text_field :body, placeholder: "Say something", class: "my-2 mr-2"%>
    <%= form.submit "Post msg", class: "p-2 cursor-pointer hover:bg-green-600" %>
  <% end %>
</div>